# wing.conf.ps1 - Local configuration overrides for Get-Wing.ps1
# Copy this file to the repo root as 'wing.conf.ps1' and edit to taste.
# Any variable set here overrides the default in Get-Wing.ps1.
# This file is gitignored.

# Commander names (order matters: first = primary monitor, rest = alt monitors)
$cmdrNames = @(
    "CMDRUnistronaut",
    "CMDRBistronaut",
    "CMDRTristronaut",
    "CMDRQuadstronaut"
)

# Executable paths
$sandboxieStart = 'C:\PATH\TO\SANDBOXIE\Start.exe'
$minEDLauncher  = 'C:\PATH\TO\STEAM\MinEdLauncher.exe'
$edmc_path      = 'C:\PATH\TO\EDMarketConnector.exe'
$edebLauncher   = 'C:\PATH\TO\EDEB\Elite Dangerous Exploration Buddy.exe'

# Feature toggles (uncomment to override)
# $config.launchEliteDangerous           = $true
# $config.launchEDEB                     = $false
# $config.launchEDMC                     = $false
# $config.skipIntro                      = $true
# $config.pgEntry                        = $true
# $config.StopCustomServicesAndProcesses = $false

# Timing (milliseconds unless noted)
# $config.WindowPollInterval         = 3333
# $config.ProcessWaitInterval        = 3333
# $config.WindowMoveRetryInterval    = 3333
# $config.MaxRetries                 = 3
# $config.EliteWindowSettleSeconds   = 7   # seconds

# Window positions for alt-monitor Elite clients
# These are X/Y pixel offsets. Negative values = left/above primary monitor.
# $eliteWindows is built from $eliteDangerousCmdrs after config loads,
# so override the $cmdrNames above to control which names appear.
